# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=taskboard
DB_PASSWORD=taskboard
DB_NAME=taskboard

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_ACCESS_SECRET=dev_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
TWO_FACTOR_ENCRYPTION_KEY=dev_two_factor_encryption_key

# Transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=TaskBoard <no-reply@example.com>

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# App
PORT=3000
FRONTEND_URL=http://localhost:5173
ENABLE_SWAGGER=true
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Service temporarily unavailable

# Error monitoring (Sentry) — leave empty to disable
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Database backup (docker-compose.prod.yml `backup` service)
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400

# Frontend
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=http://localhost:3000
# Frontend error monitoring (Sentry) — leave empty to disable
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
